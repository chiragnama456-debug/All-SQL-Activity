use world;

select c.id, c.name, c.countrycode, city.code, city.name 
from city 
join country as c
on c.countrycode = city.code;


create database selfjoindb;
use selfjoindb;

create table employees(
	eid int,
    name varchar(20),
    manager_id int
);

insert into employees values(1,'tushar', null ), (2,'abhinav', 1), (3, 'Saksham', 1), (4, 'Akshay', 2);
select * from employees;

select emp.eid, emp.name, emp.manager_id, mngr.eid, mngr.name 
from employees as emp
join employees as mngr
where emp.manager_id = mngr.eid;

select mngr.eid, mngr.name from employee as mngr;


